# Payment Service — copy this to .env and fill in your values

PORT=4000

# PayPal credentials (server-side only, never expose these)
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com

# API key — callers must send this in the X-API-Key header
# Leave blank to disable auth (development only)
API_KEY=dev-secret-key

# Comma-separated list of allowed origins for CORS
# e.g. http://localhost:3000,https://myapp.com
ALLOWED_ORIGINS=http://localhost:3000

NODE_ENV=development
